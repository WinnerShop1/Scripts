			h.Enabled = ESP_ENABLED
		end

		if d then
			d.Enabled = ESP_ENABLED
		end

	end

end)



------------------------------------------------
-- ITEM BUTTONS
------------------------------------------------

local itemList = {
	"Mossite",
	"Voltite",
	"Gildrite",
	"Rimeveil",
	"Nocturnite"
}


local y = 90


for _,name in ipairs(itemList) do


	local btn = createButton(
		name.." : เปิด",
		y
	)


	btn.BackgroundColor3 = Color3.fromRGB(0,200,100)


	btn.MouseButton1Click:Connect(function()


		ITEM_ENABLED[name] = not ITEM_ENABLED[name]


		if ITEM_ENABLED[name] then

			btn.Text = name.." : เปิด"
			btn.BackgroundColor3 = Color3.fromRGB(0,200,100)

		else

			btn.Text = name.." : ปิด"
			btn.BackgroundColor3 = Color3.fromRGB(200,50,50)

		end



		for _,obj in ipairs(workspace:GetDescendants()) do

			if obj.Name == name then

				local h = obj:FindFirstChild("ItemHighlight")
				local d = obj:FindFirstChild("DistanceESP")


				if h then
					h.Enabled = ITEM_ENABLED[name]
				end


				if d then
					d.Enabled = ITEM_ENABLED[name]
				end

			end

		end


	end)


	y = y + 40

end



------------------------------------------------
-- RIGHT CTRL UI TOGGLE
------------------------------------------------

UIS.InputBegan:Connect(function(input,gp)

	if gp then return end

	if input.KeyCode == Enum.KeyCode.RightControl then

		frame.Visible = not frame.Visible

	end

end)



------------------------------------------------
-- DISTANCE
------------------------------------------------

local function getCharacter()

	return player.Character or player.CharacterAdded:Wait()

end



local function getDistance(obj)

	local char = getCharacter()
	local root = char:FindFirstChild("HumanoidRootPart")

	if not root then
		return 0
	end


	local part


	if obj:IsA("Model") then

		part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")


	elseif obj:IsA("BasePart") then

		part = obj

	end



	if part then

		return math.floor(
			(root.Position - part.Position).Magnitude
		)

	end


	return 0

end




------------------------------------------------
-- CREATE ESP
------------------------------------------------

local function addESP(obj)


	if not TARGET_ITEMS[obj.Name] then
		return
	end


	if not ITEM_ENABLED[obj.Name] then
		return
	end


	if not ESP_ENABLED then
		return
	end



	local target


	if obj:IsA("Model") then

		target = obj

	elseif obj:IsA("BasePart") then

		target = obj

	else

		return

	end




	-- Highlight

	if not target:FindFirstChild("ItemHighlight") then


		local h = Instance.new("Highlight")

		h.Name = "ItemHighlight"
		h.Adornee = target
		h.FillColor = Color3.fromRGB(255,0,0)
		h.FillTransparency = 1
		h.OutlineColor = Color3.fromRGB(255,0,0)
		h.OutlineTransparency = 0
		h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		h.Parent = target


	end




	-- Text

	if not target:FindFirstChild("DistanceESP") then


		local bill = Instance.new("BillboardGui")

		bill.Name = "DistanceESP"
		bill.Size = UDim2.new(0,150,0,40)
		bill.StudsOffset = Vector3.new(0,3,0)
		bill.AlwaysOnTop = true
		bill.Adornee = target
		bill.Parent = target



		local text = Instance.new("TextLabel")


		text.Size = UDim2.new(1,0,1,0)
		text.BackgroundTransparency = 1
		text.TextColor3 = Color3.fromRGB(0,255,255)
		text.TextStrokeTransparency = 0
		text.TextScaled = true
		text.Font = Enum.Font.SourceSansBold
		text.Parent = bill



		task.spawn(function()


			while target.Parent do


				if ESP_ENABLED and ITEM_ENABLED[obj.Name] then

					text.Text =
						obj.Name.." ["..
						getDistance(target)
						.."m]"

				else

					text.Text = ""

				end


				task.wait(0.2)

			end


		end)

	end

end




------------------------------------------------
-- SCAN
------------------------------------------------

task.spawn(function()

	while true do


		for _,obj in ipairs(workspace:GetDescendants()) do

			addESP(obj)

		end


		task.wait(1)

	end

end)



workspace.DescendantAdded:Connect(function(obj)

	task.wait(0.1)

	addESP(obj)

end)

------------------------------------------------
-- INSTANT E SYSTEM
------------------------------------------------

local function setupPrompt(obj)

	if not obj:IsA("ProximityPrompt") then
		return
	end


	if INSTANT_E then

		obj.HoldDuration = 0
		obj.RequiresLineOfSight = false

	else

		obj.HoldDuration = 1

	end

end



-- ใช้กับของที่มีอยู่แล้ว
for _,obj in ipairs(workspace:GetDescendants()) do

	setupPrompt(obj)

end



-- ใช้กับของที่เกิดใหม่
workspace.DescendantAdded:Connect(function(obj)

	task.wait(0.1)

	setupPrompt(obj)

end)
