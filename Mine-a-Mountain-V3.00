local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer

local function CreateNameESP(player)

	if player == LocalPlayer then
		return
	end


	local nameDrawing = Drawing.new("Text")

	nameDrawing.Center = true
	nameDrawing.Outline = true
	nameDrawing.Size = 14
	nameDrawing.Font = 2
	nameDrawing.Color = Color3.fromRGB(255,255,255)
	nameDrawing.Visible = false



	RunService.RenderStepped:Connect(function()

		if not NAME_ESP_ENABLED then
			nameDrawing.Visible = false
			return
		end


		if not player.Character 
		or not player.Character:FindFirstChild("HumanoidRootPart") then

			nameDrawing.Visible = false
			return

		end



		local hrp = player.Character.HumanoidRootPart


		local pos,onScreen =
			Camera:WorldToViewportPoint(
				hrp.Position + Vector3.new(0,2.5,0)
			)



		if onScreen then

			local myChar = LocalPlayer.Character
			local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")


			local distance = 0

			if myRoot then
				distance =
					(hrp.Position - myRoot.Position).Magnitude
			end



			nameDrawing.Text =
				player.Name.." ["..
				math.floor(distance)..
				"m]"


			nameDrawing.Position =
				Vector2.new(pos.X,pos.Y)


			nameDrawing.Visible = true


		else

			nameDrawing.Visible = false

		end


	end)

end



-- ผู้เล่นที่มีอยู่แล้ว
for _,player in ipairs(Players:GetPlayers()) do
	CreateNameESP(player)
end



-- ผู้เล่นเข้าใหม่
Players.PlayerAdded:Connect(function(player)

	CreateNameESP(player)

end)

